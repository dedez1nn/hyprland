# Cache e temporários
*.cache
*.log
__pycache__/
*.pyc
.current_wallpaper

# Wallust cache gerado automaticamente
.config/wallust/cache/

# Arquivos gerados pelo wallust (sobrescritos automaticamente)
.config/waybar/wallust/
.config/rofi/wallust/
.config/kitty/kitty-themes/01-Wallust.conf
.config/hypr/wallust/wallust-hyprland.conf

# Arquivos pessoais
.config/hypr/wallpaper_effects/
.config/hypr/.initial_startup_done

# Quickshell state
.config/quickshell/GlobalStates.qml

# Waybar symlinks gerenciados pelo install.sh
.config/waybar/config
.config/waybar/style.css

# Bluetooth cache (MACs dos dispositivos do usuário)
.config/waybar/bluetooth-preferred-devices

# Fish: variáveis de ambiente geradas
.config/fish/fish_variables

# Ghostty tema gerado por wallust
.config/ghostty/wallust.conf
.config/ghostty/theme.conf
